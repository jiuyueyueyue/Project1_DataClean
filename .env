# ============================================================================
# 电商智能客服知识库 & 对话语料预处理 —— 环境变量配置
# ============================================================================
# 说明：此文件用于覆盖 config/settings.py 中的默认值。
#       正式环境部署时可注释不需要的变量，系统将使用配置类中的默认值。
# ============================================================================

# ---- 数据路径 ----
# FAQ_DATA_PATH=data/raw/faq_data.csv
# PRODUCT_DATA_PATH=data/raw/product_data.csv
# AFTERSALES_DATA_PATH=data/raw/aftersales_data.csv
# CHATLOG_DATA_PATH=data/raw/chatlog_data.csv
# CLEAN_DATA_PATH=data/processed/clean_corpus.csv
# KB_CHUNKS_PATH=data/output/kb_chunks.jsonl
# CORPUS_PLOT_PATH=data/output/corpus_distribution.png
# LOG_FILE_PATH=data/output/pipeline.log

# ---- 数据生成量 ----
# FAQ_GENERATE_COUNT=3000
# PRODUCT_GENERATE_COUNT=2000
# AFTERSALES_GENERATE_COUNT=500
# CHATLOG_GENERATE_COUNT=2000

# ---- 知识库切片 ----
# KB_CHUNK_SIZE=512
# KB_CHUNK_OVERLAP=128
# KB_MIN_CHUNK_LENGTH=50

# ---- 数据清洗 ----
# TEXT_MIN_LENGTH=5
# CSV_ENCODING=utf-8

# ---- 模型训练 ----
# RANDOM_SEED=42
# RF_N_ESTIMATORS=100
# TRAIN_TEST_SPLIT_RATIO=0.2
# TFIDF_MAX_FEATURES=5000

# ---- 可视化 ----
# PLOT_DPI=300
# SHOW_PLOT=true

# ---- 日志 ----
# LOG_LEVEL=INFO
