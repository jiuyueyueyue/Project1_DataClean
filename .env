# ============================================================================
# Project1_DataClean 环境变量配置文件
# ============================================================================
# 说明：此文件用于覆盖 config/settings.py 中的默认值。
#       所有变量均有默认值，仅在需要调整时修改。
#       正式环境部署时需将此文件加入 .gitignore（可选，视团队策略而定）
# ============================================================================

# ---- 数据路径 ----
# RAW_DATA_PATH=data/raw/raw_data.csv
# CLEAN_DATA_PATH=data/processed/clean_data.csv
# LABELED_DATA_PATH=data/labeled_data.csv
# LABEL_PLOT_PATH=data/output/label_distribution.png
# LOG_FILE_PATH=data/output/pipeline.log

# ---- 数据生成 ----
# GENERATE_TOTAL_COUNT=10000

# ---- 数据清洗 ----
# TEXT_MIN_LENGTH=5
# CLEAN_TARGET_COUNT=5800

# ---- 模型训练 ----
# RANDOM_SEED=42
# RF_N_ESTIMATORS=100
# TRAIN_TEST_SPLIT_RATIO=0.2
# TFIDF_MAX_FEATURES=5000

# ---- 可视化 ----
# PLOT_DPI=300
# SHOW_PLOT=true

# ---- 日志 ----
# LOG_LEVEL=INFO
