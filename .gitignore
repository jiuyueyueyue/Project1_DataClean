# ============================================================================
# Project1_DataClean Git 忽略规则
# ============================================================================

# --- Python 字节码 & 缓存 ---
__pycache__/
*.py[cod]
*.pyo
*.egg-info/
*.egg
dist/
build/

# --- 虚拟环境 ---
venv/
.venv/
env/
.env.venv/

# --- IDE / 编辑器 ---
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store
Thumbs.db

# --- Jupyter Notebook ---
.ipynb_checkpoints/
*.ipynb

# --- 数据文件（根据需要调整） ---
# 原始数据和清洗数据通常较大，建议不纳入版本控制
# data/raw/*.csv
# data/processed/*.csv
# 标注数据量小且为人工标注成果，建议纳入版本控制
# data/labeled_data.csv（保留）

# --- 输出产物 ---
data/output/*.png
data/output/*.log
data/output/*.pkl
data/output/*.joblib

# --- 环境变量 ---
# .env 文件根据团队策略决定是否忽略
# .env

# --- 安装包 / 二进制文件 ---
*.msi
*.exe
*.dmg
*.pkg

# --- 日志文件 ---
*.log

# --- 操作系统临时文件 ---
*.tmp
*.temp
