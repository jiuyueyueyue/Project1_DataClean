# ============================================================================
# 电商智能客服知识库 & 对话语料预处理流水线 —— Git 忽略规则
# ============================================================================

# --- Python 字节码 & 缓存 ---
__pycache__/
*.py[cod]
*.pyo
*.egg-info/
*.egg
dist/
build/

# --- 虚拟环境 ---
venv/
.venv/
env/
.env.venv/

# --- IDE / 编辑器 ---
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store
Thumbs.db

# --- Jupyter Notebook ---
.ipynb_checkpoints/
*.ipynb

# --- 数据文件 ---
# 生成数据量较大，可按需取消注释
# data/raw/*.csv
# data/processed/*.csv

# --- 输出产物 ---
data/output/*.png
data/output/*.log
data/output/*.pkl
data/output/*.joblib
data/output/*.jsonl

# --- RAG 导出目录 ---
rag_output/
rag_export/

# --- 环境变量 ---
# .env 根据团队策略决定是否忽略

# --- 安装包 / 二进制文件 ---
*.msi
*.exe
*.dmg
*.pkg

# --- 日志文件 ---
*.log

# --- 操作系统临时文件 ---
*.tmp
*.temp
